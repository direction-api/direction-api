# ============================================================
# Direction API — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# 🔑 AUTENTICAÇÃO DO PAINEL
# ----------------------------------------------------------
# Chave secreta usada para acessar o painel web.
# Defina uma string longa e aleatória (ex: openssl rand -hex 32)
GLOBAL_API_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_FORTE

# ----------------------------------------------------------
# 🐘 POSTGRESQL — Banco de Dados
# ----------------------------------------------------------
# Usuário, senha e nome do banco. Deve bater com o docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROQUE_PELA_SENHA_DO_BANCO
POSTGRES_DB=direction_db
POSTGRES_URI=postgres://postgres:TROQUE_PELA_SENHA_DO_BANCO@direction-postgres:5432/direction_db

# ----------------------------------------------------------
# 🐇 RABBITMQ — Fila de Mensagens
# ----------------------------------------------------------
# Usuário e senha do RabbitMQ. Deve bater com o docker-compose.yml
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=TROQUE_PELA_SENHA_DO_RABBITMQ
RABBITMQ_URI=amqp://admin:TROQUE_PELA_SENHA_DO_RABBITMQ@direction-rabbitmq:5672

# ----------------------------------------------------------
# 🟥 REDIS — Cache de Sessões
# ----------------------------------------------------------
REDIS_URI=redis://direction-redis:6379

# ----------------------------------------------------------
# 🌐 WEBHOOK DE SAÍDA (onde suas mensagens chegam)
# ----------------------------------------------------------
# URL do seu n8n, Make, Zapier ou qualquer webhook receptor
# O consumer.js enviará as mensagens recebidas para cá
WEBHOOK_URL=https://SEU_N8N_OU_AUTOMACAO/webhook/SEU_PATH
